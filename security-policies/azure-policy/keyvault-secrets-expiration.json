{
  "properties": {
    "displayName": "Key Vault secrets must have expiration dates",
    "policyType": "Custom",
    "mode": "All",
    "description": "This policy ensures that all secrets stored in Key Vault have expiration dates set to enforce regular key rotation.",
    "metadata": {
      "version": "1.0.0",
      "category": "Key Vault",
      "severity": "Medium"
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.KeyVault/vaults/secrets"
          },
          {
            "field": "Microsoft.KeyVault/vaults/secrets/attributes.exp",
            "exists": "false"
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}
