{
  "properties": {
    "displayName": "App Service must use HTTPS only",
    "policyType": "Custom",
    "mode": "All",
    "description": "This policy ensures that all App Services are configured to use HTTPS only, denying HTTP connections.",
    "metadata": {
      "version": "1.0.0",
      "category": "App Service",
      "severity": "High"
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy"
        },
        "allowedValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Web/sites"
          },
          {
            "field": "Microsoft.Web/sites/httpsOnly",
            "notEquals": "true"
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}
